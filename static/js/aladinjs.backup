    // PATCH 7: New API endpoint handler methods
    // ADD these new methods to handle app2 integration

    async fetchLatestAnalysis(symbol) {
        try {
            const response = await fetch(`/api/aladin/analysis/${symbol}/latest`);
            const result = await response.json();
            
            if (result.success && result.data) {
                console.log(`Analysis data fetched for ${symbol}:`, result.data);
                return result.data;
            } else {
                console.warn(`No analysis data found for ${symbol}:`, result.error);
                return null;
            }
        } catch (error) {
            console.error(`Error fetching analysis for ${symbol}:`, error);
            return null;
        }
    }

    async fetchOHLCVData(symbol, days = null) {
        try {
            const timeframe = days || this.currentTimeframe;
            const response = await fetch(`/api/aladin/chart/${symbol}/ohlcv?days=${timeframe}`);
            const result = await response.json();
            
            if (result.success && result.data && result.data.length > 0) {
                console.log(`OHLCV data fetched for ${symbol}: ${result.data.length} points`);
                return result.data;
            } else {
                console.warn(`No OHLCV data found for ${symbol}:`, result.error);
                return [];
            }
        } catch (error) {
            console.error(`Error fetching OHLCV data for ${symbol}:`, error);
            return [];
        }
    }

    // Gap Removal Patch - Add this method to ALADINStreamingClient class
    // FIX 2: Market-aware OHLCV processing (5-day week, not 7-day)
    processOHLCVWithGapRemoval(ohlcvData, gapThresholdDays = 3) {
        if (!ohlcvData || ohlcvData.length < 2) return ohlcvData;
        
        const result = [];
        const msPerDay = 24 * 60 * 60 * 1000;
        const gapThreshold = gapThresholdDays * msPerDay;
        
        // Sort by timestamp
        const sorted = [...ohlcvData].sort((a, b) => 
            new Date(a.timestamp) - new Date(b.timestamp)
        );
        
        result.push(sorted[0]); // Add first point
        
        for (let i = 1; i < sorted.length; i++) {
            const prevDate = new Date(sorted[i-1].timestamp);
            const currentDate = new Date(sorted[i].timestamp);
            const gap = currentDate.getTime() - prevDate.getTime();
            
            // MARKET FIX: Only add gap breaks for actual trading gaps (> 3 market days)
            // Don't break lines for weekends (2 days) or single holidays
            const isWeekendGap = this.isWeekendOnlyGap(prevDate, currentDate);
            
            if (gap > gapThreshold && !isWeekendGap) {
                result.push({
                    timestamp: new Date(prevDate.getTime() + msPerDay).toISOString(),
                    open: null, high: null, low: null, close: null, volume: null
                });
            }
            
            result.push(sorted[i]);
        }
        
        return result;
    }

    // FIX 2 Helper: Check if gap is only weekend
    isWeekendOnlyGap(prevDate, currentDate) {
        const daysBetween = (currentDate - prevDate) / (24 * 60 * 60 * 1000);
        
        // If gap is exactly 2-3 days and spans a weekend, it's normal
        if (daysBetween <= 3) {
            const prevDay = prevDate.getDay(); // 0=Sunday, 5=Friday, 6=Saturday
            const currentDay = currentDate.getDay();
            
            // Friday to Monday (2-3 days) is normal weekend gap
            if (prevDay === 5 && (currentDay === 1 || currentDay === 0)) {
                return true;
            }
            // Handle holidays adjacent to weekends
            if (daysBetween <= 3 && (prevDay === 5 || currentDay === 1)) {
                return true;
            }
        }
        
        return false;
    }


    // FIX 1: Correct alignChartTimeframe with original formatting preserved
    // REPLACE the existing alignChartTimeframe method with this version
    // REPLACE the existing alignChartTimeframe method with this version
    alignChartTimeframe() {
        if (!this.analysisData) {
            const errorMsg = '⚠️ No analysis data available for timeframe alignment';
            console.warn(errorMsg);
            this.showStatusUpdate(errorMsg, 'error');
            return false;
        }
        
        console.log('🔍 DEBUG: Analysis data received:', this.analysisData);
        
        let analysisPeriodDays = 90; // default
        let projectionPeriodDays = 30; // default
        let analysisSource = 'DEFAULT';
        let projectionSource = 'DEFAULT';
        
        // DEBUG: Check what timeframe fields actually contain
        console.log('📊 timeframe field:', this.analysisData.timeframe, typeof this.analysisData.timeframe);
        console.log('🎯 target_timeframe field:', this.analysisData.target_timeframe, typeof this.analysisData.target_timeframe);
        console.log('📈 data_points_analyzed:', this.analysisData.data_points_analyzed, typeof this.analysisData.data_points_analyzed);
        
        // Step 1: Extract analysis period (historical)
        if (this.analysisData.timeframe && !isNaN(parseInt(this.analysisData.timeframe))) {
            analysisPeriodDays = parseInt(this.analysisData.timeframe);
            analysisSource = 'timeframe field';
            console.log(`📊 Using timeframe: ${this.analysisData.timeframe} → ${analysisPeriodDays} days`);
        } 
        else if (this.analysisData.data_points_analyzed) {
            analysisPeriodDays = Math.ceil(this.analysisData.data_points_analyzed / 1.4);
            analysisSource = 'data_points_analyzed';
            console.log(`📊 Using data_points: ${this.analysisData.data_points_analyzed} → ${analysisPeriodDays} days`);
        }
        else {
            const warnMsg = '⚠️ No valid timeframe data - using default 90 days';
            console.warn(warnMsg);
            this.showStatusUpdate(warnMsg, 'warning');
        }
        
        // Step 2: Extract projection period (future)
        if (this.analysisData.target_timeframe) {
            projectionPeriodDays = this.parseTimeframeToDays(this.analysisData.target_timeframe);
            projectionSource = 'target_timeframe';
            console.log(`🎯 Using target_timeframe: "${this.analysisData.target_timeframe}" → ${projectionPeriodDays} days`);
        } 
        else if (this.analysisData.timeframe_outlook) {
            // Try to get from timeframe_outlook
            try {
                const outlook = typeof this.analysisData.timeframe_outlook === 'string' 
                    ? JSON.parse(this.analysisData.timeframe_outlook)
                    : this.analysisData.timeframe_outlook;
                
                const firstKey = Object.keys(outlook)[0];
                if (firstKey) {
                    projectionPeriodDays = this.parseTimeframeToDays(firstKey);
                    projectionSource = 'timeframe_outlook';
                    console.log(`🎯 Using timeframe_outlook: "${firstKey}" → ${projectionPeriodDays} days`);
                }
            } catch (e) {
                console.warn('❌ Failed to parse timeframe_outlook:', e);
            }
        }
        else {
            const warnMsg = '⚠️ No projection timeframe - using default 30 days';
            console.warn(warnMsg);
            this.showStatusUpdate(warnMsg, 'warning');
        }
        
        // Step 3: Final calculation
        const totalTimeframeDays = analysisPeriodDays + projectionPeriodDays;
        
        console.log('📊 FINAL TIMEFRAME CALCULATION:');
        console.log(`   Analysis: ${analysisPeriodDays}d (from ${analysisSource})`);
        console.log(`   Projection: ${projectionPeriodDays}d (from ${projectionSource})`);
        console.log(`   Total: ${totalTimeframeDays}d`);
        
        // Show user what we found
        const statusMsg = `Chart: ${analysisPeriodDays}d historical + ${projectionPeriodDays}d projection`;
        this.showStatusUpdate(statusMsg, 'info');
        
        // Step 4: Update if needed
        if (totalTimeframeDays !== this.currentTimeframe) {
            const oldTimeframe = this.currentTimeframe;
            this.currentTimeframe = totalTimeframeDays;
            this.analysisDays = analysisPeriodDays;
            this.projectionDays = projectionPeriodDays;
            
            console.log(`🔄 Updating chart timeframe: ${oldTimeframe} → ${this.currentTimeframe} days`);
            
            const selector = document.getElementById('timeframe-selector');
            if (selector) {
                selector.value = this.currentTimeframe;
            }
            
            return true;
        }
        
        console.log('✅ Chart timeframe already aligned');
        return false;
    }

    // Helper method to extract projection period from text
    extractProjectionFromText(text) {
        if (!text) return 30; // default
        
        const textLower = text.toLowerCase();
        
        // Look for explicit timeframe mentions
        if (textLower.includes('1 week') || textLower.includes('weekly')) return 7;
        if (textLower.includes('2 week') || textLower.includes('biweekly')) return 14;
        if (textLower.includes('1 month') || textLower.includes('monthly')) return 30;
        if (textLower.includes('2 month')) return 60;
        if (textLower.includes('3 month') || textLower.includes('quarterly')) return 90;
        if (textLower.includes('6 month')) return 180;
        if (textLower.includes('1 year') || textLower.includes('yearly')) return 365;
        
        // Look for specific day mentions
        const dayMatch = text.match(/(\d+)\s*days?\b/i);
        if (dayMatch) {
            const days = parseInt(dayMatch[1]);
            if (days > 0 && days < 1000) return days;
        }
        
        return 30; // fallback
    }

    // Enhanced parseTimeframeToDays method
    // ENHANCE this method to handle intraday and other timeframes
    parseTimeframeToDays(timeframe) {
        if (!timeframe) return 30;
        
        const timeframeStr = String(timeframe).toLowerCase().trim();
        console.log('🔍 Parsing timeframe:', timeframeStr);
        
        // Handle numeric values directly
        if (!isNaN(timeframeStr)) {
            const days = parseInt(timeframeStr);
            return Math.min(365, Math.max(1, days)); // Limit to reasonable range
        }
        
        // Handle text timeframes - ADD INTRADAY SUPPORT
        const mapping = {
            // INTRADAY TIMEFRAMES - ADD THESE
            'intraday': 1, 'intra_day': 1, 'daily': 1, '1d': 1, '1_day': 1,
            'today': 1, 'current_day': 1, 'day': 1,
            
            // EXISTING MAPPINGS
            '1_week': 7, '1week': 7, 'weekly': 7, '7days': 7, '7_days': 7,
            '2_weeks': 14, '2weeks': 14, 'biweekly': 14, '14days': 14, '14_days': 14,
            '1_month': 30, '1month': 30, 'monthly': 30, '30days': 30, '30_days': 30,
            '2_months': 60, '2months': 60, '60days': 60, '60_days': 60,
            '3_months': 90, '3months': 90, 'quarterly': 90, '90days': 90, '90_days': 90,
            '6_months': 180, '6months': 180, 'half_year': 180, '180days': 180, '180_days': 180,
            '1_year': 365, '1year': 365, 'yearly': 365, '365days': 365, '365_days': 365
        };
        
        const result = mapping[timeframeStr] || 30;
        console.log(`   → Parsed "${timeframeStr}" as: ${result} days`);
        return result;
    }

    // DEBUGGING: Show the simple mapping
    debugSimpleMapping() {
        if (!this.analysisData) {
            console.log('❌ No analysis data');
            return;
        }
        
        console.log('🔍 SIMPLE MAPPING DEBUG:');
        console.log('📊 Analysis period source:');
        console.log(`   timeframe field: ${this.analysisData.timeframe} (${typeof this.analysisData.timeframe})`);
        console.log(`   → Analysis days: ${parseInt(this.analysisData.timeframe || 90)}`);
        
        console.log('📊 Projection period source:');
        console.log(`   target_timeframe: "${this.analysisData.target_timeframe}"`);
        console.log(`   timeframe_outlook keys: ${this.analysisData.timeframe_outlook ? Object.keys(this.analysisData.timeframe_outlook) : 'none'}`);
        
        if (this.analysisData.chart_visualization_data?.timeframe_outlook) {
            console.log(`   chart_viz timeframe_outlook: ${Object.keys(this.analysisData.chart_visualization_data.timeframe_outlook)}`);
        }
        
        const projectionDays = this.parseTimeframeToDays(
            this.analysisData.target_timeframe || 
            (this.analysisData.timeframe_outlook ? Object.keys(this.analysisData.timeframe_outlook)[0] : null)
        );
        console.log(`   → Projection days: ${projectionDays}`);
        
        console.log('📊 Final calculation:');
        const analysisDays = parseInt(this.analysisData.timeframe || 90);
        console.log(`   Total X-axis: ${analysisDays} + ${projectionDays} = ${analysisDays + projectionDays} days`);
    }

    // QUICK TEST: Verify the mapping works
    testTimeframeMapping() {
        console.log('🧪 TESTING TIMEFRAME MAPPING:');
        
        // Test analysis period parsing
        const testAnalysisPeriods = [60, 90, '60', '90'];
        testAnalysisPeriods.forEach(period => {
            const days = parseInt(period);
            console.log(`   timeframe ${period} → ${days} days`);
        });
        
        // Test projection period parsing  
        const testProjectionPeriods = ['1_month', '3_months', '6_months', '1_year'];
        testProjectionPeriods.forEach(period => {
            const days = this.parseTimeframeToDays(period);
            console.log(`   ${period} → ${days} days`);
        });
    }

    // Enhanced updateChartTitle method
    updateChartTitle() {
        if (!this.priceChart) return;
        
        // Build descriptive title
        let titleText = `${this.currentSymbol} Analysis`;
        
        if (this.analysisDays && this.projectionDays) {
            titleText += ` (${this.analysisDays}d analysis + ${this.projectionDays}d projection)`;
        } else {
            titleText += ` (${this.currentTimeframe} days)`;
        }
        
        // Update chart title
        if (!this.priceChart.options.plugins.title) {
            this.priceChart.options.plugins.title = { display: true };
        }
        
        this.priceChart.options.plugins.title.text = titleText;
        console.log(`📊 Chart title updated: ${titleText}`);
    }

    // Debug method to inspect analysis data
    debugAnalysisTimeframe() {
        if (!this.analysisData) {
            console.log('❌ No analysis data available');
            return;
        }
        
        console.log('🔍 TIMEFRAME DEBUG INFO:');
        console.log('📊 Raw analysis data keys:', Object.keys(this.analysisData));
        
        // Check all possible timeframe fields
        const timeframeFields = [
            'analysis_timeframe', 'timeframe', 'target_timeframe', 
            'period_days', 'data_points_analyzed', 'timeframe_predictions'
        ];
        
        timeframeFields.forEach(field => {
            const value = this.analysisData[field];
            console.log(`   ${field}: ${value} (${typeof value})`);
        });
        
        if (this.chartVisualizationData) {
            console.log('🎯 Chart visualization data available');
            if (this.chartVisualizationData.targets) {
                console.log(`   Targets: ${this.chartVisualizationData.targets.length}`);
                this.chartVisualizationData.targets.forEach((target, i) => {
                    console.log(`   Target ${i+1}: price=${target.price}, timeframe=${target.timeframe}`);
                });
            }
        }
    }

    // Test method to validate timeframe alignment
    testTimeframeAlignment() {
        console.log('🧪 TESTING TIMEFRAME ALIGNMENT...');
        
        // Test with mock analysis data
        this.analysisData = {
            period_days: 90,
            data_points_analyzed: 126, // 90 trading days
            analysis_timeframe: '3_months',
            target_timeframe: '1_month',
            timeframe_predictions: 'Based on 1 month outlook, targets expected within 30 days'
        };
        
        this.chartVisualizationData = {
            targets: [
                { price: 350, timeframe: '1_month' },
                { price: 365, timeframe: '2_months' }
            ]
        };
        
        console.log('📊 Mock data created, running alignment...');
        const updated = this.alignChartTimeframe();
        
        console.log(`✅ Test complete. Timeframe updated: ${updated}`);
        console.log(`   Final timeframe: ${this.currentTimeframe} days`);
        console.log(`   Analysis period: ${this.analysisDays} days`);
        console.log(`   Projection period: ${this.projectionDays} days`);
    }

    // PATCH 8: Progress handling methods
    // ADD these methods for enhanced progress tracking

    showAnalysisProgress(update) {
        if (update.stage) {
            const stages = {
                'data_loading': 'Loading market data...',
                'analysis_running': 'Running technical analysis...',
                'chart_generation': 'Generating chart data...',
                'finalization': 'Finalizing results...'
            };
            
            const message = stages[update.stage] || 'Processing...';
            this.showStatusUpdate(`Processing: ${message}`, 'info');
        }
    }

    handleDataLoadComplete(update) {
        if (update.symbol && update.data_points) {
            this.showStatusUpdate(`Data loaded: ${update.data_points} points for ${update.symbol}`, 'success');
        }
    }
}





